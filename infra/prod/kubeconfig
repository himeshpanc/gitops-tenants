apiVersion: v1
kind: Config
clusters:
  - name: c
    cluster:
      server: https://kubernetes.default.svc
      insecure-skip-tls-verify: true
contexts:
  - name: c
    context:
      cluster: c
      user: u
current-context: c
users:
  - name: u
    user:
      # Secret-free: the token is fetched at runtime from $KUBE_TOKEN (set by the
      # promotion step from the tf-kube Kargo secret). No credential lives in git.
      exec:
        apiVersion: client.authentication.k8s.io/v1
        command: sh
        args:
          - -c
          - "printf '{\"apiVersion\":\"client.authentication.k8s.io/v1\",\"kind\":\"ExecCredential\",\"status\":{\"token\":\"%s\"}}' \"$KUBE_TOKEN\""
        interactiveMode: Never
        provideClusterInfo: false
